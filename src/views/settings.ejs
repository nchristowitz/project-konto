<%- include('header') %>
<h1>Settings</h1>

<div class="card">
  <h2>Business Profile</h2>
  <form method="POST" action="/settings/profile">
    <div class="form-grid">
      <div class="form-group full">
        <label for="name">Business name</label>
        <input type="text" id="name" name="name" value="<%= profile ? profile.name : '' %>" required>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="<%= profile ? profile.email : '' %>">
      </div>
      <div class="form-group">
        <label for="phone">Phone</label>
        <input type="text" id="phone" name="phone" value="<%= profile ? profile.phone : '' %>">
      </div>
      <div class="form-group full">
        <label for="address_line1">Address line 1</label>
        <input type="text" id="address_line1" name="address_line1" value="<%= profile ? profile.address_line1 : '' %>">
      </div>
      <div class="form-group full">
        <label for="address_line2">Address line 2</label>
        <input type="text" id="address_line2" name="address_line2" value="<%= profile ? profile.address_line2 : '' %>">
      </div>
      <div class="form-group">
        <label for="city">City</label>
        <input type="text" id="city" name="city" value="<%= profile ? profile.city : '' %>">
      </div>
      <div class="form-group">
        <label for="postal_code">Postal code</label>
        <input type="text" id="postal_code" name="postal_code" value="<%= profile ? profile.postal_code : '' %>">
      </div>
      <div class="form-group">
        <label for="country_code">Country code</label>
        <input type="text" id="country_code" name="country_code" maxlength="2" value="<%= profile ? profile.country_code : 'DE' %>">
      </div>
      <div class="form-group">
        <label for="website">Website</label>
        <input type="text" id="website" name="website" value="<%= profile ? profile.website : '' %>">
      </div>
      <div class="form-group">
        <label for="vat_number">VAT number</label>
        <input type="text" id="vat_number" name="vat_number" value="<%= profile ? profile.vat_number : '' %>">
      </div>
      <div class="form-group">
        <label for="tax_number">Tax number</label>
        <input type="text" id="tax_number" name="tax_number" value="<%= profile ? profile.tax_number : '' %>">
      </div>
    </div>
    <button type="submit">Save profile</button>
  </form>
</div>

<div class="card">
  <h2>Bank Accounts</h2>

  <div id="bank-accounts">
    <% for (const ba of bankAccounts) { %>
    <div class="ba-card">
      <!-- View mode -->
      <div class="ba-view">
        <div class="ba-head">
          <div class="ba-title">
            <strong><%= ba.label %></strong>
            <% if (ba.is_default) { %><span class="status status-paid">Default</span><% } %>
          </div>
          <div class="ba-actions">
            <% if (!ba.is_default) { %>
            <form method="POST" action="/settings/bank-accounts/<%= ba.id %>/default" class="inline-form">
              <button type="submit" class="small" data-variant="secondary">Set default</button>
            </form>
            <% } %>
            <button type="button" class="small ba-edit-btn" data-variant="secondary">Edit</button>
            <form method="POST" action="/settings/bank-accounts/<%= ba.id %>/delete" class="inline-form">
              <button type="submit" class="small outline" data-variant="danger" onclick="return confirm('Delete this bank account?')">Delete</button>
            </form>
          </div>
        </div>
        <div class="ba-meta">
          <% if (ba.account_holder) { %><div>Account holder: <%= ba.account_holder %></div><% } %>
          <% if (ba.bank_name) { %><div>Bank: <%= ba.bank_name %></div><% } %>
          <% if (ba.iban) { %><div>IBAN: <%= ba.iban %></div><% } %>
          <% if (ba.bic) { %><div>BIC: <%= ba.bic %></div><% } %>
          <% if (ba.account_number) { %><div>Account: <%= ba.account_number %></div><% } %>
          <% if (ba.routing_number) { %><div>Routing: <%= ba.routing_number %></div><% } %>
          <% if (ba.swift_code) { %><div>SWIFT: <%= ba.swift_code %></div><% } %>
        </div>
      </div>
      <!-- Edit mode (hidden by default) -->
      <div class="ba-edit" style="display:none">
        <form method="POST" action="/settings/bank-accounts/<%= ba.id %>">
          <div class="form-grid">
            <div class="form-group">
              <label>Label</label>
              <input type="text" name="label" value="<%= ba.label %>" required>
            </div>
            <div class="form-group">
              <label>Bank name</label>
              <input type="text" name="bank_name" value="<%= ba.bank_name || '' %>">
            </div>
            <div class="form-group">
              <label>Account holder</label>
              <input type="text" name="account_holder" value="<%= ba.account_holder || '' %>">
            </div>
            <div class="form-group">
              <label>IBAN</label>
              <input type="text" name="iban" value="<%= ba.iban || '' %>">
            </div>
            <div class="form-group">
              <label>BIC</label>
              <input type="text" name="bic" value="<%= ba.bic || '' %>">
            </div>
            <div class="form-group">
              <label>Account number</label>
              <input type="text" name="account_number" value="<%= ba.account_number || '' %>">
            </div>
            <div class="form-group">
              <label>Routing number</label>
              <input type="text" name="routing_number" value="<%= ba.routing_number || '' %>">
            </div>
            <div class="form-group">
              <label>SWIFT code</label>
              <input type="text" name="swift_code" value="<%= ba.swift_code || '' %>">
            </div>
            <div class="form-group">
              <label>&nbsp;</label>
              <label class="checkbox-label">
                <input type="checkbox" name="is_default" <%= ba.is_default ? 'checked' : '' %>>
                Default account
              </label>
            </div>
          </div>
          <div class="ba-form-actions">
            <button type="submit">Save</button>
            <button type="button" class="ba-cancel-btn" data-variant="secondary">Cancel</button>
          </div>
        </form>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Add new bank account (hidden by default) -->
  <div id="ba-new-form" class="ba-card" style="display:none">
    <form method="POST" action="/settings/bank-accounts">
      <div class="form-grid">
        <div class="form-group">
          <label>Label</label>
          <input type="text" name="label" required>
        </div>
        <div class="form-group">
          <label>Bank name</label>
          <input type="text" name="bank_name">
        </div>
        <div class="form-group">
          <label>Account holder</label>
          <input type="text" name="account_holder">
        </div>
        <div class="form-group">
          <label>IBAN</label>
          <input type="text" name="iban">
        </div>
        <div class="form-group">
          <label>BIC</label>
          <input type="text" name="bic">
        </div>
        <div class="form-group">
          <label>Account number</label>
          <input type="text" name="account_number">
        </div>
        <div class="form-group">
          <label>Routing number</label>
          <input type="text" name="routing_number">
        </div>
        <div class="form-group">
          <label>SWIFT code</label>
          <input type="text" name="swift_code">
        </div>
        <div class="form-group">
          <label>&nbsp;</label>
          <label class="checkbox-label">
            <input type="checkbox" name="is_default">
            Default account
          </label>
        </div>
      </div>
      <div class="ba-form-actions">
        <button type="submit">Add account</button>
        <button type="button" data-variant="secondary" id="ba-cancel-new">Cancel</button>
      </div>
    </form>
  </div>

  <button type="button" id="ba-add-btn" data-variant="secondary">+ Add bank account</button>
</div>

<script>
(function() {
  // Toggle edit/view on existing cards
  document.getElementById('bank-accounts').addEventListener('click', function(e) {
    const card = e.target.closest('.ba-card');
    if (!card) return;
    if (e.target.classList.contains('ba-edit-btn')) {
      card.querySelector('.ba-view').style.display = 'none';
      card.querySelector('.ba-edit').style.display = '';
    }
    if (e.target.classList.contains('ba-cancel-btn')) {
      card.querySelector('.ba-view').style.display = '';
      card.querySelector('.ba-edit').style.display = 'none';
    }
  });

  // Add new form toggle
  var newForm = document.getElementById('ba-new-form');
  var addBtn = document.getElementById('ba-add-btn');
  addBtn.addEventListener('click', function() {
    newForm.style.display = '';
    addBtn.style.display = 'none';
    newForm.querySelector('input[name="label"]').focus();
  });
  document.getElementById('ba-cancel-new').addEventListener('click', function() {
    newForm.style.display = 'none';
    addBtn.style.display = '';
  });
})();
</script>

<div class="card">
  <h2>Defaults & Reminders</h2>
  <form method="POST" action="/settings">
    <div class="form-grid">
      <div class="form-group">
        <label for="default_currency">Default currency</label>
        <input type="text" id="default_currency" name="default_currency" maxlength="3" value="<%= settings.default_currency %>">
      </div>
      <div class="form-group">
        <label for="default_vat_rate">Default VAT rate (%)</label>
        <input type="number" id="default_vat_rate" name="default_vat_rate" step="0.01" value="<%= settings.default_vat_rate %>">
      </div>
      <div class="form-group">
        <label for="default_payment_terms">Payment terms (days)</label>
        <input type="number" id="default_payment_terms" name="default_payment_terms" value="<%= settings.default_payment_terms %>">
      </div>
      <div class="form-group">
        <label>&nbsp;</label>
        <label class="checkbox-label">
          <input type="checkbox" name="reminder_enabled" <%= settings.reminder_enabled ? 'checked' : '' %>>
          Enable overdue reminders
        </label>
      </div>
      <div class="form-group">
        <label for="reminder_interval_days">Reminder interval (days)</label>
        <input type="number" id="reminder_interval_days" name="reminder_interval_days" value="<%= settings.reminder_interval_days %>">
      </div>
      <div class="form-group">
        <label for="max_reminders">Max reminders</label>
        <input type="number" id="max_reminders" name="max_reminders" value="<%= settings.max_reminders %>">
      </div>
      <div class="form-group full">
        <label for="default_payment_details">Default payment details</label>
        <textarea id="default_payment_details" name="default_payment_details" rows="4"><%= settings.default_payment_details || '' %></textarea>
      </div>
      <div class="form-group full">
        <label for="default_notes">Default invoice notes</label>
        <textarea id="default_notes" name="default_notes" rows="3"><%= settings.default_notes || '' %></textarea>
      </div>
    </div>
    <button type="submit">Save settings</button>
  </form>
</div>

<%
  const targets = settings.revenue_targets || {};
  const currentYear = new Date().getFullYear();
  const targetYears = [currentYear, currentYear + 1];
%>
<div class="card">
  <h2>Revenue Targets</h2>
  <form method="POST" action="/settings/targets">
    <div class="form-grid">
      <% for (const y of targetYears) { %>
        <div class="form-group">
          <label for="target_<%= y %>"><%= y %> target (EUR)</label>
          <input type="number" id="target_<%= y %>" name="target_<%= y %>" step="1" value="<%= targets[y] || '' %>" placeholder="e.g. 150000">
        </div>
      <% } %>
    </div>
    <button type="submit">Save targets</button>
  </form>
</div>

<div class="card">
  <h2>Exports</h2>
  <p class="text-secondary mb-4">CSV exports for your tax advisor (semicolon-delimited, opens directly in Excel). Invoices are listed by issue date; payments by date received — the EÜR-relevant view.</p>
  <% if (exportYears.length === 0) { %>
    <p class="empty">No invoices to export yet.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Year</th>
          <th class="text-right">Downloads</th>
        </tr>
      </thead>
      <tbody>
        <% for (const y of exportYears) { %>
          <tr>
            <td><%= y %></td>
            <td class="text-right">
              <span class="export-actions">
                <a href="/settings/export/invoices.csv?year=<%= y %>" class="button small" data-variant="secondary">Invoices CSV</a>
                <a href="/settings/export/payments.csv?year=<%= y %>" class="button small" data-variant="secondary">Payments CSV</a>
              </span>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card">
  <h2>Data Reset</h2>
  <p class="text-secondary mb-4">Permanently delete data. This cannot be undone. You must type the confirmation phrase exactly.</p>
  <div class="form-actions">
    <form method="POST" action="/settings/reset" class="inline-form" data-confirm-phrase="delete invoices" data-confirm-message="This will delete ALL invoices, payments, and email logs. Type &quot;delete invoices&quot; to confirm:">
      <input type="hidden" name="action" value="invoices">
      <button type="submit" class="outline" data-variant="danger">Delete all invoices</button>
    </form>
    <form method="POST" action="/settings/reset" class="inline-form" data-confirm-phrase="delete estimates" data-confirm-message="This will delete ALL estimates. Type &quot;delete estimates&quot; to confirm:">
      <input type="hidden" name="action" value="estimates">
      <button type="submit" class="outline" data-variant="danger">Delete all estimates</button>
    </form>
    <form method="POST" action="/settings/reset" class="inline-form" data-confirm-phrase="delete clients" data-confirm-message="This will delete ALL clients AND all their invoices and estimates. Type &quot;delete clients&quot; to confirm:">
      <input type="hidden" name="action" value="clients">
      <button type="submit" class="outline" data-variant="danger">Delete all clients</button>
    </form>
    <form method="POST" action="/settings/reset" class="inline-form" data-confirm-phrase="delete everything" data-confirm-message="This will wipe EVERYTHING: clients, invoices, estimates, payments, and numbering sequences. Type &quot;delete everything&quot; to confirm:">
      <input type="hidden" name="action" value="all">
      <button type="submit" class="outline" data-variant="danger">Delete everything</button>
    </form>
  </div>
</div>

<script>
// Typed-confirmation gate on data reset forms. The confirmation phrase is
// intentionally distinct per action so muscle memory can't rubber-stamp the
// destructive one. Comparison is case-insensitive + whitespace-trimmed.
document.querySelectorAll('form[data-confirm-phrase]').forEach(function(form) {
  form.addEventListener('submit', function(e) {
    var expected = form.dataset.confirmPhrase;
    var message = form.dataset.confirmMessage;
    var typed = window.prompt(message);
    if (typed === null || typed.trim().toLowerCase() !== expected) {
      e.preventDefault();
      if (typed !== null) window.alert('Phrase did not match. No changes made.');
    }
  });
});
</script>
<%- include('footer') %>
