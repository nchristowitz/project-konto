<%- include('../header') %>
<% if (query.error) { %>
  <div class="notice notice-error"><%= query.error %></div>
<% } %>
<div class="page-header">
  <h1>Invoices</h1>
  <a href="/invoices/new" class="btn">New invoice</a>
</div>

<div class="filters">
  <a href="/invoices" class="filter-tag <%= !filters.status ? 'active' : '' %>">All</a>
  <a href="/invoices?status=draft" class="filter-tag <%= filters.status === 'draft' ? 'active' : '' %>">Draft</a>
  <a href="/invoices?status=sent" class="filter-tag <%= filters.status === 'sent' ? 'active' : '' %>">Sent</a>
  <a href="/invoices?status=viewed" class="filter-tag <%= filters.status === 'viewed' ? 'active' : '' %>">Viewed</a>
  <a href="/invoices?status=paid" class="filter-tag <%= filters.status === 'paid' ? 'active' : '' %>">Paid</a>
  <a href="/invoices?status=overdue" class="filter-tag <%= filters.status === 'overdue' ? 'active' : '' %>">Overdue</a>
  <a href="/invoices?status=cancelled" class="filter-tag <%= filters.status === 'cancelled' ? 'active' : '' %>">Cancelled</a>
</div>

<% if (invoices.length === 0) { %>
  <p class="empty">No invoices yet.</p>
<% } else { %>
  <div class="card">
    <div class="batch-bar">
      <form method="POST" action="/invoices/export" class="inline-form" id="export-form">
        <span id="hidden-ids-export"></span>
        <button type="submit" class="btn-secondary btn-small" id="export-btn" disabled>Export</button>
      </form>
      <form method="POST" action="/invoices/batch" class="inline-form" id="cancel-form">
        <span id="hidden-ids-cancel"></span>
        <input type="hidden" name="action" value="cancel">
        <button type="submit" class="btn-secondary btn-small" id="cancel-btn" disabled>Cancel</button>
      </form>
      <form method="POST" action="/invoices/batch" class="inline-form" id="delete-form">
        <span id="hidden-ids-delete"></span>
        <input type="hidden" name="action" value="delete">
        <button type="submit" class="btn-danger btn-small" id="delete-btn" disabled>Delete</button>
      </form>
    </div>
    <table>
      <thead>
        <tr>
          <th style="width:32px"><input type="checkbox" id="select-all"></th>
          <th data-sort="text">Number</th>
          <th data-sort="text">Client</th>
          <th data-sort="date">Date</th>
          <th data-sort="date">Due</th>
          <th class="text-right" data-sort="number">Total</th>
          <th class="text-right" data-sort="status">Status</th>
        </tr>
      </thead>
      <tbody>
        <% for (const inv of invoices) { %>
          <tr>
            <td><input type="checkbox" name="invoice_ids" value="<%= inv.id %>" class="row-check"></td>
            <td data-value="<%= inv.number %>"><a href="/invoices/<%= inv.id %>"><%= inv.number %></a></td>
            <td data-value="<%= inv.client_name %>"><%= inv.client_name %></td>
            <td data-value="<%= inv.issue_date ? new Date(inv.issue_date).toISOString().slice(0, 10) : '' %>"><%= inv.issue_date ? new Date(inv.issue_date).toISOString().slice(0, 10) : '' %></td>
            <td data-value="<%= inv.due_date ? new Date(inv.due_date).toISOString().slice(0, 10) : '' %>"><%= inv.due_date ? new Date(inv.due_date).toISOString().slice(0, 10) : '' %></td>
            <td class="text-right" data-value="<%= Number(inv.total) %>"><%= fmt(inv.total) %> <%= inv.currency %></td>
            <td class="text-right" data-value="<%= inv.status %>"><span class="status status-<%= inv.status %>"><%= inv.status %></span></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <script>
    (function() {
      var all = document.getElementById('select-all');
      var checks = document.querySelectorAll('.row-check');
      var btns = [document.getElementById('export-btn'), document.getElementById('cancel-btn'), document.getElementById('delete-btn')];
      var hiddenContainers = {
        export: document.getElementById('hidden-ids-export'),
        cancel: document.getElementById('hidden-ids-cancel'),
        delete: document.getElementById('hidden-ids-delete'),
      };
      function update() {
        var selected = Array.from(checks).filter(function(c) { return c.checked; });
        var any = selected.length > 0;
        btns.forEach(function(b) { b.disabled = !any; });
        all.checked = checks.length > 0 && selected.length === checks.length;
        // Sync hidden inputs to each form
        Object.keys(hiddenContainers).forEach(function(key) {
          hiddenContainers[key].innerHTML = selected.map(function(c) {
            return '<input type="hidden" name="invoice_ids" value="' + c.value + '">';
          }).join('');
        });
      }
      all.addEventListener('change', function() {
        checks.forEach(function(c) { c.checked = all.checked; });
        update();
      });
      checks.forEach(function(c) { c.addEventListener('change', update); });
      document.getElementById('delete-form').addEventListener('submit', function(e) {
        if (!confirm('Delete selected invoices? Only drafts and cancelled will be removed.')) e.preventDefault();
      });
    })();
  </script>
<% } %>
<%- include('../footer') %>
